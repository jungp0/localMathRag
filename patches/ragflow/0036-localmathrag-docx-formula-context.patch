+def _merge_chunk_image(target, source):
+    source_image = source.get("image")
+    if source_image is None:
+        return
+    if target.get("image") is None:
+        target["image"] = source_image
+        return
+    target["image"] = LazyImage.merge(target["image"], source_image)
+
+
+def _formula_chunk_text(chunk):
+    latex = (chunk.get("_docx_formula_latex") or "").strip()
+    if latex:
+        return f"$$\n{latex}\n$$"
+    sources = chunk.get("_docx_formula_sources") or []
+    names = [source.get("prog_id") for source in sources if isinstance(source, dict) and source.get("prog_id")]
+    source_name = ", ".join(dict.fromkeys(names)) or "Equation Editor"
+    return f"[{source_name} formula image]"
+
+
+def _coalesce_docx_formula_chunks(chunks, formula_indices):
+    if not formula_indices:
+        for chunk in chunks:
+            for key in ("_docx_paragraph_id", "_docx_anchor_text", "_docx_formula_sources", "_docx_formula_latex"):
+                chunk.pop(key, None)
+        return [idx for idx, chunk in enumerate(chunks) if chunk.get("ck_type") == "image" and chunk.get("image") is not None]
+
+    remove_indices = set()
+    for formula_idx in sorted(formula_indices):
+        if not (0 <= formula_idx < len(chunks)):
+            continue
+        formula_chunk = chunks[formula_idx]
+        paragraph_id = formula_chunk.get("_docx_paragraph_id")
+        anchor_idx = None
+        if paragraph_id:
+            for idx, chunk in enumerate(chunks):
+                if idx == formula_idx or chunk.get("ck_type") != "text":
+                    continue
+                if paragraph_id in chunk.get("_docx_paragraph_ids", []):
+                    anchor_idx = idx
+                    break
+        if anchor_idx is None:
+            candidates = [
+                idx
+                for idx, chunk in enumerate(chunks)
+                if idx != formula_idx and chunk.get("ck_type") == "text"
+            ]
+            if candidates:
+                anchor_idx = min(candidates, key=lambda idx: (abs(idx - formula_idx), idx > formula_idx))
+
+        formula_text = _formula_chunk_text(formula_chunk)
+        if anchor_idx is None:
+            formula_chunk["text"] = formula_text
+            formula_chunk["ck_type"] = "formula"
+            formula_chunk["tk_nums"] = num_tokens_from_string(formula_text)
+            continue
+
+        anchor = chunks[anchor_idx]
+        anchor_text = (formula_chunk.get("_docx_anchor_text") or "").strip()
+        current_text = anchor.get("text") or ""
+        insertion = f"{anchor_text}\n{formula_text}" if anchor_text else formula_text
+        if anchor_text and anchor_text in current_text:
+            anchor["text"] = current_text.replace(anchor_text, insertion, 1)
+        elif formula_text not in current_text:
+            anchor["text"] = f"{current_text.rstrip()}\n{formula_text}".strip()
+        anchor["tk_nums"] = num_tokens_from_string(anchor.get("text") or "")
+        anchor["_docx_has_formula"] = True
+        _merge_chunk_image(anchor, formula_chunk)
+        remove_indices.add(formula_idx)
+
+    chunks[:] = [chunk for idx, chunk in enumerate(chunks) if idx not in remove_indices]
+    for chunk in chunks:
+        for key in ("_docx_paragraph_id", "_docx_anchor_text", "_docx_formula_sources", "_docx_formula_latex"):
+            chunk.pop(key, None)
