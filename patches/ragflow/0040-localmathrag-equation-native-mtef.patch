+    def __equation_native_latex(self, relationship_id):
+        if not relationship_id:
+            return ""
+        if relationship_id in self._equation_native_cache:
+            return self._equation_native_cache[relationship_id]
+
+        latex = ""
+        converter = os.environ.get("LOCALMATHRAG_MTEF_PARSER", "/usr/local/bin/localmathrag-mtef")
+        try:
+            related_part = self.doc.part.related_parts[relationship_id]
+            ole_blob = getattr(related_part, "blob", None)
+            if not ole_blob or not os.path.isfile(converter):
+                self._equation_native_cache[relationship_id] = ""
+                return ""
+            timeout_seconds = float(os.environ.get("LOCALMATHRAG_MTEF_TIMEOUT_SECONDS", "5"))
+            completed = subprocess.run(
+                [converter],
+                input=ole_blob,
+                capture_output=True,
+                check=False,
+                timeout=max(0.2, timeout_seconds),
+            )
+            if completed.returncode == 0:
+                text = completed.stdout.decode("utf-8", errors="replace").strip()
+                wrapped = re.fullmatch(r"\$\$\s*(.*?)\s*\$\$", text, flags=re.DOTALL)
+                latex = (wrapped.group(1) if wrapped else text).strip()
+                if len(latex) > 100000:
+                    latex = ""
+            else:
+                detail = completed.stderr.decode("utf-8", errors="replace").strip()
+                logging.info("Equation Native MTEF parser skipped %s: %s", relationship_id, detail)
+        except (KeyError, OSError, subprocess.TimeoutExpired, ValueError) as exc:
+            logging.info("Equation Native MTEF parser skipped %s: %s", relationship_id, exc)
+
+        self._equation_native_cache[relationship_id] = latex
+        return latex
