+    def __omml_text(self, element):
+        def text_of(node):
+            name = self.__local_name(node)
+            if name == "t":
+                return node.text or ""
+
+            children = list(node)
+            if name in {"num", "den", "e", "deg", "sub", "sup"}:
+                return "".join(text_of(child) for child in children)
+            if name == "f":
+                num = "".join(text_of(child) for child in children if self.__local_name(child) == "num")
+                den = "".join(text_of(child) for child in children if self.__local_name(child) == "den")
+                return f"({num})/({den})" if num or den else ""
+            if name == "sSub":
+                base = "".join(text_of(child) for child in children if self.__local_name(child) == "e")
+                sub = "".join(text_of(child) for child in children if self.__local_name(child) == "sub")
+                return f"{base}_{sub}" if sub else base
+            if name == "sSup":
+                base = "".join(text_of(child) for child in children if self.__local_name(child) == "e")
+                sup = "".join(text_of(child) for child in children if self.__local_name(child) == "sup")
+                return f"{base}^{sup}" if sup else base
+            if name == "sSubSup":
+                base = "".join(text_of(child) for child in children if self.__local_name(child) == "e")
+                sub = "".join(text_of(child) for child in children if self.__local_name(child) == "sub")
+                sup = "".join(text_of(child) for child in children if self.__local_name(child) == "sup")
+                if sub and sup:
+                    return f"{base}_{sub}^{sup}"
+                if sub:
+                    return f"{base}_{sub}"
+                return f"{base}^{sup}" if sup else base
+            if name == "rad":
+                deg = "".join(text_of(child) for child in children if self.__local_name(child) == "deg")
+                body = "".join(text_of(child) for child in children if self.__local_name(child) == "e")
+                return f"root[{deg}]({body})" if deg else f"sqrt({body})"
+
+            return "".join(text_of(child) for child in children)
+
+        formulas = []
+        seen = set()
+        for math in element.xpath(".//m:oMath | .//m:oMathPara"):
+            formula = re.sub(r"\s+", " ", text_of(math)).strip()
+            if not formula or formula in seen:
