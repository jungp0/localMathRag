+    def __omml_text(self, element):
+        def local_name(node):
+            return node.tag.rsplit("}", 1)[-1]
+
+        def text_of(node):
+            name = local_name(node)
+            if name == "t":
+                return node.text or ""
+
+            children = list(node)
+            if name in {"num", "den", "e", "deg", "sub", "sup"}:
+                return "".join(text_of(child) for child in children)
+            if name == "f":
+                num = "".join(text_of(child) for child in children if local_name(child) == "num")
+                den = "".join(text_of(child) for child in children if local_name(child) == "den")
+                return f"({num})/({den})" if num or den else ""
+            if name == "sSub":
+                base = "".join(text_of(child) for child in children if local_name(child) == "e")
+                sub = "".join(text_of(child) for child in children if local_name(child) == "sub")
+                return f"{base}_{sub}" if sub else base
+            if name == "sSup":
+                base = "".join(text_of(child) for child in children if local_name(child) == "e")
+                sup = "".join(text_of(child) for child in children if local_name(child) == "sup")
+                return f"{base}^{sup}" if sup else base
+            if name == "sSubSup":
+                base = "".join(text_of(child) for child in children if local_name(child) == "e")
+                sub = "".join(text_of(child) for child in children if local_name(child) == "sub")
+                sup = "".join(text_of(child) for child in children if local_name(child) == "sup")
+                if sub and sup:
+                    return f"{base}_{sub}^{sup}"
+                if sub:
+                    return f"{base}_{sub}"
+                return f"{base}^{sup}" if sup else base
+            if name == "rad":
+                deg = "".join(text_of(child) for child in children if local_name(child) == "deg")
+                body = "".join(text_of(child) for child in children if local_name(child) == "e")
+                return f"root[{deg}]({body})" if deg else f"sqrt({body})"
+
+            return "".join(text_of(child) for child in children)
+
+        formulas = []
+        seen = set()
+        for math in element.xpath(".//m:oMath | .//m:oMathPara"):
+            formula = re.sub(r"\s+", " ", text_of(math)).strip()
+            if not formula or formula in seen:
+                continue
+            seen.add(formula)
+            formulas.append(f"{self.WORD_EQUATION_PREFIX} {formula}]")
+        return " ".join(formulas)
+
+    def __paragraph_text_with_math_placeholders(self, paragraph):
+        pieces = []
+        for run in paragraph.runs:
+            if run.text:
+                pieces.append(run.text)
+            equation_text = self.__omml_text(run._element)
+            if equation_text:
+                pieces.append(equation_text)
+        paragraph_equations = self.__omml_text(paragraph._element)
+        text = "".join(pieces).strip()
+        if paragraph_equations and paragraph_equations not in text:
+            text = f"{text} {paragraph_equations}".strip()
+        return text
+
+    def __image_placeholder(self, paragraph, context_text=""):
+        metadata = []
+        try:
+            for pic in paragraph._element.xpath(".//pic:pic"):
+                for prop in pic.xpath(".//pic:cNvPr"):
+                    title = prop.get("title")
+                    descr = prop.get("descr")
+                    metadata.extend([v for v in (title, descr) if v])
+        except Exception:
+            metadata = []
+        label = "; ".join(dict.fromkeys([m.strip() for m in metadata if m.strip()]))
+        placeholder = self.WORD_INLINE_IMAGE_PLACEHOLDER if not label else f"{self.WORD_INLINE_IMAGE_PLACEHOLDER} {label}"
+        context_text = self.__clean(context_text)
+        if context_text:
+            return f"{context_text}\n{placeholder}"
+        return placeholder
+
