+def _stream_id_tuple(stream_id) -> tuple[int, int]:
+    if isinstance(stream_id, bytes):
+        stream_id = stream_id.decode("utf-8", errors="replace")
+    major, _, minor = str(stream_id or "0-0").partition("-")
+    try:
+        return int(major), int(minor or 0)
+    except ValueError:
+        return 0, 0
+
+
+def remove_stale_auxiliary_index_messages(
+    task_ids: set[str] | None = None,
+    doc_ids: set[str] | None = None,
+    worker_task_type: str = "common",
+) -> set[str]:
+    """Cancel and remove queued/pending auxiliary messages matching a task or dataset."""
+    task_ids = {str(task_id) for task_id in (task_ids or set()) if task_id}
+    doc_ids = {str(doc_id) for doc_id in (doc_ids or set()) if doc_id}
+    if not task_ids and not doc_ids:
+        return set()
+
+    queue_name = settings.get_svr_queue_name(AUXILIARY_INDEX_PRIORITY, worker_task_type)
+    try:
+        groups = REDIS_CONN.REDIS.xinfo_groups(queue_name)
+    except Exception as exc:
+        if "no such key" not in str(exc).lower():
+            logging.warning("Unable to inspect auxiliary queue %s: %s", queue_name, exc)
+        return set()
+
+    group = next((item for item in groups if item.get("name") == SVR_CONSUMER_GROUP_NAME), None)
+    last_delivered_id = (group or {}).get("last-delivered-id", "0-0")
+    pending_ids: set[str] = set()
+    if group:
+        try:
+            pending = REDIS_CONN.REDIS.xpending_range(queue_name, SVR_CONSUMER_GROUP_NAME, "-", "+", 10000)
+            pending_ids = {
+                item.get("message_id").decode("utf-8", errors="replace")
+                if isinstance(item.get("message_id"), bytes)
+                else str(item.get("message_id"))
+                for item in pending
+            }
+        except Exception as exc:
+            logging.warning("Unable to inspect pending auxiliary tasks on %s: %s", queue_name, exc)
+            return set()
+
+    try:
+        entries = REDIS_CONN.REDIS.xrange(queue_name, "-", "+")
+    except Exception as exc:
+        logging.warning("Unable to scan auxiliary queue %s: %s", queue_name, exc)
+        return set()
+
+    matched_task_ids: set[str] = set()
+    pipeline = REDIS_CONN.REDIS.pipeline(transaction=True)
+    for message_id, payload in entries:
+        normalized_message_id = message_id.decode("utf-8", errors="replace") if isinstance(message_id, bytes) else str(message_id)
+        is_pending = normalized_message_id in pending_ids
+        is_queued = _stream_id_tuple(normalized_message_id) > _stream_id_tuple(last_delivered_id)
+        if not is_pending and not is_queued:
+            continue
+        try:
+            raw_message = payload.get("message", payload.get(b"message", "{}"))
+            if isinstance(raw_message, bytes):
+                raw_message = raw_message.decode("utf-8", errors="replace")
+            message = json.loads(raw_message)
+        except (TypeError, ValueError):
+            continue
+        if message.get("task_type") not in AUXILIARY_INDEX_TASK_TYPES:
+            continue
+        message_task_id = str(message.get("id") or "")
+        message_doc_ids = {str(doc_id) for doc_id in (message.get("doc_ids") or []) if doc_id}
+        if message_task_id not in task_ids and not (doc_ids & message_doc_ids):
+            continue
+        matched_task_ids.add(message_task_id)
+        pipeline.set(f"{message_task_id}-cancel", "x")
+        if group:
+            pipeline.xack(queue_name, SVR_CONSUMER_GROUP_NAME, message_id)
+        pipeline.xdel(queue_name, message_id)
+
+    if matched_task_ids:
+        pipeline.execute()
+        logging.info("Removed %d stale auxiliary queue message(s): %s", len(matched_task_ids), sorted(matched_task_ids))
+    return matched_task_ids
 
 
