+def _localmathrag_int_env(name, default, minimum=1):
+    raw = os.environ.get(name)
+    if raw is None:
+        return default
+    try:
+        return max(minimum, int(raw))
+    except (TypeError, ValueError):
+        logging.warning("Invalid %s=%r; using %s", name, raw, default)
+        return default
+
+
+def _localmathrag_search_progress(stage, percent, message, **extra):
+    return {
+        "stage": stage,
+        "percent": max(0, min(100, int(percent))),
+        "message": message,
+        **extra,
+    }
 
 
