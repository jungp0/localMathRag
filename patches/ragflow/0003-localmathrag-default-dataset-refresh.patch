+import hashlib
+import json
+import logging
+import os
+import threading
+import time
+from pathlib import Path
+from typing import Any
+
+from api.db.db_models import DB
+from api.db.services.document_service import DocumentService
+from api.db.services.file_service import FileService
+from api.db.services.knowledgebase_service import KnowledgebaseService
+from api.db.services.user_service import TenantService, UserService
+from api.utils.file_utils import filename_type
+from common.constants import ParserType, StatusEnum, TaskStatus
+
+
+DEFAULT_DATASET_NAME = os.environ.get("LOCALMATHRAG_DEFAULT_DATASET_NAME", "Default")
+DEFAULT_USER_EMAIL = os.environ.get("LOCALMATHRAG_DEFAULT_USER_EMAIL", "admin@ragflow.io")
+DATASET_DIR = Path(os.environ.get("LOCALMATHRAG_DATASET_DIR", "/localmathrag/dataset"))
+DATASET_STATE_FILE = Path(os.environ.get("LOCALMATHRAG_DATASET_STATE_FILE", "/localmathrag/cache/dataset-state.json"))
+REFRESH_LOCK = threading.Lock()
+
+
+class LocalDatasetFile:
+    def __init__(self, path: Path, rel_path: str, doc_id: str, fingerprint: str):
+        self.path = path
+        self.filename = rel_path
+        self.id = doc_id
+        self.fingerprint = fingerprint
+
+    def read(self) -> bytes:
+        return self.path.read_bytes()
+
+
+def _now() -> float:
+    return time.time()
+
+
+def _doc_id(rel_path: str) -> str:
+    return hashlib.sha1(f"localmathrag:default:{rel_path}".encode("utf-8")).hexdigest()[:32]
+
+
+def _signature(path: Path) -> dict[str, int]:
+    stat = path.stat()
+    data = {
+        "mtime_ns": int(stat.st_mtime_ns),
+        "ctime_ns": int(stat.st_ctime_ns),
+    }
+    if path.is_file():
+        data["size"] = int(stat.st_size)
+    return data
+
+
+def _fingerprint(rel_path: str, signature: dict[str, int]) -> str:
+    seed = {"path": rel_path, "signature": signature}
+    return hashlib.sha1(json.dumps(seed, sort_keys=True).encode("utf-8")).hexdigest()[:32]
+
+
+def _relative_path(path: Path) -> str:
+    rel = path.relative_to(DATASET_DIR).as_posix()
+    return "" if rel == "." else rel
+
+
+def _parent_path(path: str) -> str:
+    if not path or "/" not in path:
+        return ""
+    return path.rsplit("/", 1)[0]
+
+
+def _load_state() -> dict[str, Any]:
+    if not DATASET_STATE_FILE.exists():
+        return {}
+    try:
+        state = json.loads(DATASET_STATE_FILE.read_text(encoding="utf-8-sig"))
+    except (OSError, json.JSONDecodeError):
+        return {}
+    return state if isinstance(state, dict) else {}
+
+
+def _write_state(entries: list[dict[str, Any]]) -> None:
+    DATASET_STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
+    durable_entries = []
+    for entry in entries:
+        if entry.get("status") == "deleted":
+            continue
+        durable_entries.append(
+            {
+                key: entry[key]
+                for key in ("path", "name", "kind", "signature", "size", "modified_at", "doc_id", "fingerprint")
+                if key in entry
+            }
+        )
+    DATASET_STATE_FILE.write_text(
+        json.dumps(
+            {
+                "version": 1,
+                "dataset_dir": str(DATASET_DIR),
+                "dataset_name": DEFAULT_DATASET_NAME,
+                "scanned_at": _now(),
+                "entries": durable_entries,
+            },
+            ensure_ascii=False,
+            indent=2,
+        ),
+        encoding="utf-8",
+    )
+
+
+def _entry(path: Path, kind: str, status: str, signature: dict[str, int], skipped: bool = False) -> dict[str, Any]:
+    rel = _relative_path(path)
+    entry: dict[str, Any] = {
+        "path": rel,
+        "name": path.name if rel else DATASET_DIR.name,
+        "kind": kind,
+        "status": status,
+        "signature": signature,
+        "modified_at": signature["mtime_ns"] / 1_000_000_000,
+    }
+    if kind == "file":
+        entry["size"] = signature.get("size", 0)
+        entry["doc_id"] = _doc_id(rel)
+        entry["fingerprint"] = _fingerprint(rel, signature)
+    if skipped:
+        entry["skipped"] = True
+    return entry
+
+
+def _cached_subtree(previous_entries: list[dict[str, Any]], rel: str, status: str) -> list[dict[str, Any]]:
+    prefix = f"{rel}/" if rel else ""
+    cached = []
+    for previous in previous_entries:
+        previous_path = str(previous.get("path", ""))
+        if previous_path == rel or not rel or previous_path.startswith(prefix):
+            copied = dict(previous)
+            copied["status"] = status
+            if copied.get("kind") == "directory":
+                copied["skipped"] = status == "unchanged"
+            cached.append(copied)
+    return cached
+
+
+def _deleted_subtree(previous_entries: list[dict[str, Any]], rel: str) -> list[dict[str, Any]]:
+    deleted = _cached_subtree(previous_entries, rel, "deleted")
+    for entry in deleted:
+        entry.pop("skipped", None)
+    return deleted
+
+
+def _scan_directory(path: Path, previous_entries: list[dict[str, Any]], previous_by_path: dict[str, dict[str, Any]]) -> list[dict[str, Any]]:
+    rel = _relative_path(path)
+    signature = _signature(path)
+    previous = previous_by_path.get(rel)
+    if previous and previous.get("kind") == "directory" and previous.get("signature") == signature:
+        cached = _cached_subtree(previous_entries, rel, "unchanged")
+        if cached:
+            return cached
+
+    status = "new" if previous is None else "changed"
+    entries = [_entry(path, "directory", status, signature)]
+    current_children: set[str] = set()
+    try:
+        children = sorted(path.iterdir(), key=lambda item: item.name.lower())
+    except OSError as exc:
+        entries[0]["error"] = str(exc)
+        return entries
+
+    for child in children:
+        try:
+            child_rel = _relative_path(child)
+            current_children.add(child_rel)
+            if child.is_dir():
+                entries.extend(_scan_directory(child, previous_entries, previous_by_path))
+            elif child.is_file():
+                child_signature = _signature(child)
+                previous_file = previous_by_path.get(child_rel)
+                child_status = "new"
+                if previous_file and previous_file.get("kind") == "file":
+                    child_status = "unchanged" if previous_file.get("signature") == child_signature else "changed"
+                entries.append(_entry(child, "file", child_status, child_signature))
+        except OSError as exc:
+            entries.append({"path": _relative_path(child), "name": child.name, "kind": "unknown", "status": "error", "error": str(exc)})
+
+    for previous_entry in previous_entries:
+        previous_path = str(previous_entry.get("path", ""))
+        if previous_path and _parent_path(previous_path) == rel and previous_path not in current_children:
+            if previous_entry.get("kind") == "directory":
+                entries.extend(_deleted_subtree(previous_entries, previous_path))
+            else:
+                deleted = dict(previous_entry)
+                deleted["status"] = "deleted"
+                deleted.setdefault("doc_id", _doc_id(previous_path))
+                entries.append(deleted)
+
+    return entries
+
+
+def _scan_manifest() -> list[dict[str, Any]]:
+    DATASET_DIR.mkdir(parents=True, exist_ok=True)
+    state = _load_state()
+    previous_entries = [
+        entry
+        for entry in state.get("entries", [])
+        if isinstance(entry, dict) and isinstance(entry.get("path", ""), str)
+    ]
+    previous_by_path = {str(entry.get("path", "")): entry for entry in previous_entries}
+    entries = _scan_directory(DATASET_DIR, previous_entries, previous_by_path)
+    _write_state(entries)
+    return entries
+
+
+def _summary(entries: list[dict[str, Any]]) -> dict[str, Any]:
+    return {
+        "file_count": sum(1 for entry in entries if entry.get("kind") == "file" and entry.get("status") != "deleted"),
+        "directory_count": sum(1 for entry in entries if entry.get("kind") == "directory" and entry.get("status") != "deleted"),
+        "new_count": sum(1 for entry in entries if entry.get("status") == "new"),
+        "changed_count": sum(1 for entry in entries if entry.get("status") == "changed"),
+        "deleted_count": sum(1 for entry in entries if entry.get("status") == "deleted"),
+        "skipped_directory_count": sum(1 for entry in entries if entry.get("kind") == "directory" and entry.get("skipped")),
+    }
+
+
+def _default_user():
+    users = UserService.query(email=DEFAULT_USER_EMAIL, status=StatusEnum.VALID.value)
+    if users:
+        return users[0]
+    users = UserService.query(is_superuser=True, status=StatusEnum.VALID.value)
+    return users[0] if users else None
+
+
+@DB.connection_context()
+def ensure_default_dataset():
+    user = _default_user()
+    if not user:
+        logging.warning("LocalMathRAGFlow default dataset skipped: no default user found")
+        return None
+
+    existing = KnowledgebaseService.get_or_none(name=DEFAULT_DATASET_NAME, tenant_id=user.id, status=StatusEnum.VALID.value)
+    if existing:
+        return existing
+
+    ok, tenant = TenantService.get_by_id(user.id)
+    if not ok:
+        logging.warning("LocalMathRAGFlow default dataset skipped: tenant not found for user %s", user.id)
+        return None
+
+    ok, create_dict = KnowledgebaseService.create_with_name(
+        name=DEFAULT_DATASET_NAME,
+        tenant_id=user.id,
+        parser_id=ParserType.NAIVE.value,
+        description="LocalMathRAGFlow default local dataset.",
+    )
+    if not ok:
+        raise RuntimeError(create_dict)
+    create_dict["embd_id"] = create_dict.get("embd_id") or tenant.embd_id
+    if not KnowledgebaseService.save(**create_dict):
+        raise RuntimeError("Failed to save LocalMathRAGFlow default dataset")
+    ok, dataset = KnowledgebaseService.get_by_id(create_dict["id"])
+    return dataset if ok else None
+
+
+def _upload_changed_files(kb, entries: list[dict[str, Any]], tenant_id: str) -> tuple[int, list[str]]:
+    changed_entries = [
+        entry
+        for entry in entries
+        if entry.get("kind") == "file" and entry.get("status") in {"new", "changed"}
+    ]
+    files = []
+    for entry in changed_entries:
+        rel = str(entry.get("path") or "")
+        file_path = DATASET_DIR / rel
+        if not file_path.is_file():
+            continue
+        if filename_type(rel) == "other":
+            logging.info("LocalMathRAGFlow skipping unsupported local dataset file: %s", rel)
+            continue
+        files.append(LocalDatasetFile(file_path, rel, str(entry["doc_id"]), str(entry["fingerprint"])))
+    if not files:
+        return 0, []
+
+    errors, parsed_files = FileService().upload_document(kb, files, tenant_id, src="localmathrag")
+    kb_table_num_map: dict[str, int] = {}
+    for doc, _ in parsed_files:
+        doc["run"] = TaskStatus.RUNNING.value
+        DocumentService.update_by_id(doc["id"], {"run": TaskStatus.RUNNING.value, "progress": 0, "progress_msg": ""})
+        DocumentService.run(tenant_id, doc, kb_table_num_map)
+    return len(parsed_files), errors
+
+
+def _delete_removed_files(entries: list[dict[str, Any]], tenant_id: str) -> tuple[int, str]:
+    doc_ids = [
+        str(entry.get("doc_id") or _doc_id(str(entry.get("path") or "")))
+        for entry in entries
+        if entry.get("kind") == "file" and entry.get("status") == "deleted"
+    ]
+    if not doc_ids:
+        return 0, ""
+    error = FileService.delete_docs(doc_ids, tenant_id)
+    return len(doc_ids), error
+
+
+def refresh_local_dataset(tenant_id: str, dataset_id: str) -> tuple[bool, dict[str, Any] | str]:
+    if not REFRESH_LOCK.acquire(blocking=False):
+        return True, {"running": True, "message": "Local dataset refresh is already running."}
+    try:
+        kb = KnowledgebaseService.get_or_none(id=dataset_id, tenant_id=tenant_id, status=StatusEnum.VALID.value)
+        if kb is None:
+            return False, "Dataset not found."
+        if kb.name != DEFAULT_DATASET_NAME:
+            return False, f"Local folder refresh is only available for the {DEFAULT_DATASET_NAME} dataset."
+
+        entries = _scan_manifest()
+        uploaded_count, upload_errors = _upload_changed_files(kb, entries, tenant_id)
+        deleted_count, delete_error = _delete_removed_files(entries, tenant_id)
+        return True, {
+            "running": False,
+            "dataset_id": dataset_id,
+            "dataset_name": DEFAULT_DATASET_NAME,
+            "dataset_dir": str(DATASET_DIR),
+            "state_file": str(DATASET_STATE_FILE),
+            "uploaded_count": uploaded_count,
+            "deleted_count": deleted_count,
+            "upload_errors": upload_errors,
+            "delete_error": delete_error,
+            "summary": _summary(entries),
+        }
+    finally:
+        REFRESH_LOCK.release()
