+def _drop_unresolved_toc_fragments(candidates: list[dict[str, Any]], chunks: list[str]) -> list[dict[str, Any]]:
+    if not chunks:
+        return candidates
+    leading_chunk_limit = min(len(chunks), max(4, (len(chunks) + 9) // 10))
+    leading_text = "\n".join(chunks[:leading_chunk_limit])
+    if not re.search(r"(?:\u76ee\s*\u5f55|\bcontents\b)", leading_text, re.IGNORECASE):
+        return candidates
+    return [
+        item
+        for item in candidates
+        if not (
+            item["chunk_id"] < leading_chunk_limit
+            and item["source"] in {"numbered", "semantic"}
+            and _strip_trailing_page_number(item["title"])[1] is not None
+        )
+    ]
+
+
 def _dedupe_and_normalize(candidates: list[dict[str, Any]]) -> list[dict[str, str]]:
     priorities = {"rendered_toc": 0, "outline": 1, "numbered": 2, "semantic": 3, "caption": 4}
     candidates.sort(key=lambda item: (item["chunk_id"], item["offset"], priorities.get(item["source"], 9)))
