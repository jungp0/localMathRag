+def _runtime_switch_failure_message(result: dict) -> str:
+    kind = str(result.get("kind") or "model runtime")
+    resource = result.get("resource_status") if isinstance(result.get("resource_status"), dict) else {}
+    available = resource.get("available_memory_gb")
+    required = resource.get("min_available_memory_gb")
+    if isinstance(available, (int, float)) and isinstance(required, (int, float)):
+        return (
+            f"Local runtime model switch failed: {kind} requires at least {required:.1f}GB available memory, "
+            f"but only {available:.1f}GB is available. Close memory-heavy applications or choose a smaller model."
+        )
+    return f"Local runtime model switch failed: {result.get('reason') or result.get('detail') or result}"
