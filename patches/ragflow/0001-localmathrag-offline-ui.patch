+async def _load_document_blob(doc):
+    """Load the original document bytes, preferring File2Document but falling back to the doc object."""
+    candidates = []
+
+    try:
+        b, n = File2DocumentService.get_storage_address(doc_id=doc.id)
+        candidates.append(("file2document", b, n))
+    except Exception as e:
+        logging.warning("Failed to resolve File2Document storage for document %s: %s", doc.id, e)
+
+    candidates.append(("document", doc.kb_id, doc.location))
+
+    seen = set()
+    for source, bucket, name in candidates:
+        if not bucket or not name:
+            continue
+        key = (str(bucket), str(name))
+        if key in seen:
+            continue
+        seen.add(key)
+        data = await thread_pool_exec(settings.STORAGE_IMPL.get, bucket, name)
+        if data:
+            if source != "file2document":
+                logging.warning(
+                    "Loaded document %s from fallback storage %s/%s after File2Document lookup failed or was empty.",
+                    doc.id,
+                    bucket,
+                    name,
+                )
+            return data
+
+    return None
+
