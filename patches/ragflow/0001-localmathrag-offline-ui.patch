+def _is_local_openai_compatible(factory: str, base_url: str | None) -> bool:
+    if factory not in {"OpenAI-API-Compatible", "VLLM", "LM-Studio"}:
+        return False
+    normalized = (base_url or "").lower()
+    return any(
+        marker in normalized
+        for marker in (
+            "127.0.0.1",
+            "localhost",
+            "host.docker.internal",
+            "localmathrag",
+            "llama",
+        )
+    )
+
+
+def _check_local_chat_completion(mdl) -> bool:
+    response = mdl.client.chat.completions.create(
+        model=mdl.model_name,
+        messages=[{"role": "user", "content": "Hi"}],
+        temperature=0,
+        max_completion_tokens=1,
+        stream=False,
+        extra_body={"enable_thinking": False},
+    )
+    return bool(getattr(response, "choices", None))
+
+
+def _defer_local_non_chat_check(factory: str, base_url: str | None, model_type: str | None) -> bool:
+    return _is_local_openai_compatible(factory, base_url) and model_type in {
+        LLMType.EMBEDDING.value,
+        LLMType.RERANK.value,
+        LLMType.IMAGE2TEXT.value,
+        LLMType.OCR.value,
+    }
+
