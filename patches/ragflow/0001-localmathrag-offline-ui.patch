+
+def _runtime_ensure_url() -> str:
+    return os.environ.get("LOCALMATHRAG_RUNTIME_ENSURE_URL", f"{OBJECT_SERVICE_URL}/v1/runtime/ensure")
+
+
+def _ensure_vision_runtime(callback=None) -> bool:
+    payload = json.dumps({"kind": "vision", "timeout_seconds": VISION_READY_TIMEOUT_SECONDS, "start": True}).encode("utf-8")
+    req = urllib.request.Request(
+        _runtime_ensure_url(),
+        data=payload,
+        headers={"Content-Type": "application/json"},
+        method="POST",
+    )
+    try:
+        if callback:
+            callback(0.7, "Visual model detected. Loading local VLM runtime if needed...")
+        with urllib.request.urlopen(req, timeout=VISION_READY_TIMEOUT_SECONDS + 5) as response:
+            data = json.loads(response.read().decode("utf-8"))
+        if data.get("ready"):
+            if callback and data.get("started"):
+                callback(0.72, "Local VLM runtime is ready.")
+            return True
+        reason = data.get("reason") or "runtime is not ready"
+        logging.warning("Visual model enhancement skipped: %s", reason)
+        if callback:
+            callback(0.72, f"Visual model not ready after waiting; skipping image enhancement. {reason}")
+        return False
+    except Exception as e:
+        logging.warning("Visual model enhancement skipped: %s", e)
+        if callback:
+            callback(0.72, f"Visual model not ready; skipping image enhancement. {e}")
+        return False
+
+
+def _get_ready_vision_model(kwargs, callback=None):
+    if not _ensure_vision_runtime(callback):
+        return None
+    try:
+        vision_model_config = get_tenant_default_model_by_type(kwargs["tenant_id"], LLMType.IMAGE2TEXT)
+        return LLMBundle(kwargs["tenant_id"], vision_model_config)
+    except Exception as e:
+        logging.warning("Visual model enhancement skipped: %s", e)
+        return None
+
+
+def _vision_enhancement_callback(callback):
+    def wrapped(progress, msg):
+        if progress is not None and progress < 0:
+            logging.warning("Visual model enhancement skipped: %s", msg)
+            return
+        if callback:
+            callback(progress, msg)
+
+    return wrapped
+
