+
+const LEGACY_OLE_HEADER = [0xd0, 0xcf, 0x11, 0xe0];
+
+const isLegacyOleDocument = async (blob: Blob): Promise<boolean> => {
+  const buf = await blob.slice(0, LEGACY_OLE_HEADER.length).arrayBuffer();
+  const bytes = new Uint8Array(buf);
+  return LEGACY_OLE_HEADER.every((value, idx) => bytes[idx] === value);
+};
+
+const looksLikeText = (sample: string): boolean => {
+  if (!sample) return false;
+
+  let controlCharCount = 0;
+  for (const char of sample) {
+    const code = char.charCodeAt(0);
+    if (
+      (code >= 0 && code <= 8) ||
+      code === 11 ||
+      code === 12 ||
+      (code >= 14 && code <= 31)
+    ) {
+      controlCharCount += 1;
+    }
+  }
+
+  return controlCharCount / sample.length < 0.02;
+};
+
+const stripRtfForPreview = (value: string): string => {
+  return value
+    .replace(/\\par[d]? ?/g, '\n')
+    .replace(/\\line ?/g, '\n')
+    .replace(/\\tab ?/g, '\t')
+    .replace(/\\'[0-9a-fA-F]{2}/g, ' ')
+    .replace(/\\[a-zA-Z]+-?\d* ?/g, '')
+    .replace(/[{}]/g, '')
+    .replace(/\n{3,}/g, '\n\n')
+    .trim();
+};
+
+const getNonDocxBlobError = async (blob: Blob): Promise<string> => {
+  if (await isLegacyOleDocument(blob)) {
+    return 'This is a legacy OLE Word .doc file, or a .docx extension over .doc content. Please download it and resave it as a modern .docx file.';
+  }
+
+  const prefix = await blob.slice(0, 512).text();
+  const trimmed = prefix.trimStart();
+
+  if (trimmed.startsWith('{')) {
+    try {
+      const payload = JSON.parse(await blob.text());
+      if (payload?.message) {
+        return payload.message;
+      }
+    } catch {
+      // Fall through to the generic header message.
+    }
+  }
+
+  if (trimmed.startsWith('<')) {
+    return 'This file is HTML/XML content, not a ZIP-based modern .docx package.';
+  }
+
+  return 'This file header does not indicate a .docx ZIP archive. Only .docx files are supported.';
+};
+
+const getWordFallbackPreview = async (
+  blob: Blob,
+): Promise<WordFallbackPreview | null> => {
+  if (await isLegacyOleDocument(blob)) {
+    return null;
+  }
+
+  const prefix = await blob.slice(0, 4096).text();
+  const trimmed = prefix.trimStart();
+
+  if (!trimmed || trimmed.startsWith('{')) {
+    return null;
+  }
+
+  const body = await blob.text();
+  const lowerPrefix = trimmed.toLowerCase();
+
+  if (
+    lowerPrefix.startsWith('<!doctype html') ||
+    lowerPrefix.startsWith('<html') ||
+    lowerPrefix.startsWith('<body') ||
+    lowerPrefix.includes('<meta name=generator content="microsoft word"') ||
+    lowerPrefix.includes('<meta name="generator" content="microsoft word"')
+  ) {
+    return {
+      body,
+      kind: 'html',
+      note: 'Rendered as HTML because the file content is not a ZIP-based modern .docx package.',
+      title: 'Word-compatible HTML preview',
+    };
+  }
+
+  if (trimmed.startsWith('{\\rtf')) {
+    return {
+      body: stripRtfForPreview(body),
+      kind: 'text',
+      note: 'Rendered as plain text because the file content is RTF, not modern .docx.',
+      title: 'RTF text preview',
+    };
+  }
+
+  if (lowerPrefix.startsWith('<?xml') || looksLikeText(prefix)) {
+    return {
+      body,
+      kind: 'text',
+      note: 'Rendered as text because the file content is not a ZIP-based modern .docx package.',
+      title: lowerPrefix.startsWith('<?xml')
+        ? 'XML text preview'
+        : 'Text preview',
+    };
+  }
+
+  return null;
+};
