+@contextmanager
+def localmathrag_embedding_purpose(purpose: str):
+    token = LOCALMATHRAG_EMBEDDING_PURPOSE.set(purpose)
+    try:
+        yield
+    finally:
+        LOCALMATHRAG_EMBEDDING_PURPOSE.reset(token)
+
+
+def _localmathrag_embedding_extra_body():
+    purpose = LOCALMATHRAG_EMBEDDING_PURPOSE.get()
