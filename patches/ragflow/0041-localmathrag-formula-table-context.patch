+def _coalesce_docx_formula_tables(chunks):
+    """Attach formula-only Word layout tables to their preceding text chunk."""
+    merged = []
+    for chunk in chunks:
+        text = str(chunk.get("text") or "")
+        formula_only_table = chunk.get("ck_type") == "table" and "$$" in text and chunk.get("image") is None
+        if formula_only_table:
+            outside_formula = re.sub(r"\$\$.*?\$\$", "", text, flags=re.DOTALL)
+            outside_formula = unescape(re.sub(r"<[^>]+>", "", outside_formula))
+            formula_only_table = not re.sub(r"[\W_]+", "", outside_formula, flags=re.UNICODE)
+
+        if formula_only_table:
+            anchor = next((item for item in reversed(merged) if item.get("ck_type") == "text"), None)
+            if anchor is not None:
+                anchor["text"] = f"{(anchor.get('text') or '').rstrip()}\n{text.strip()}".strip()
+                anchor["tk_nums"] = num_tokens_from_string(anchor["text"])
+                anchor["_docx_has_formula"] = True
+                continue
+        merged.append(chunk)
+    return merged
+
