 async def gen_mindmap(question, kb_ids, tenant_id, search_config={}):
+    def _mindmap_sections(chunks):
+        max_chunks = _localmathrag_int_env("LOCALMATHRAG_SEARCH_MINDMAP_MAX_CHUNKS", 6, minimum=1)
+        max_chars = _localmathrag_int_env("LOCALMATHRAG_SEARCH_MINDMAP_MAX_CHARS", 12000, minimum=1000)
+        sections = []
+        total_chars = 0
+        for chunk in chunks[:max_chunks]:
+            text = chunk.get("content_with_weight") or ""
+            if not text:
+                continue
+            remaining = max_chars - total_chars
+            if remaining <= 0:
+                break
+            if len(text) > remaining:
+                text = text[:remaining]
+            sections.append(text)
+            total_chars += len(text)
+        if len(chunks) > max_chunks or total_chars >= max_chars:
+            logging.info(
+                "LocalMathRAG mindmap input trimmed: chunks=%s/%s chars=%s/%s",
+                len(sections),
+                len(chunks),
+                total_chars,
+                max_chars,
+            )
+        return sections
+
