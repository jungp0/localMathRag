+class LocalMathRAGSummaryTimeout(Exception):
+    pass
+
+
+def _localmathrag_float_env(name, default, minimum=0.1):
+    raw = os.environ.get(name)
+    if raw is None:
+        return default
+    try:
+        return max(minimum, float(raw))
+    except (TypeError, ValueError):
+        logging.warning("Invalid %s=%r; using %s", name, raw, default)
+        return default
+
+
+def _localmathrag_search_budget_attempts(answer_budget, knowledge_budget):
+    max_retries = _localmathrag_int_env("LOCALMATHRAG_SEARCH_SUMMARY_MAX_RETRIES", 1, 0)
+    ratio = _localmathrag_float_env("LOCALMATHRAG_SEARCH_SUMMARY_RETRY_BUDGET_RATIO", 0.5, 0.1)
+    min_answer = _localmathrag_int_env("LOCALMATHRAG_SEARCH_SUMMARY_MIN_ANSWER_TOKENS", 384, 64)
+    min_knowledge = _localmathrag_int_env("LOCALMATHRAG_SEARCH_SUMMARY_MIN_KNOWLEDGE_TOKENS", 1024, 256)
+    attempts = []
+    for index in range(max_retries + 1):
+        factor = ratio ** index
+        answer = max(min_answer, int(answer_budget * factor))
+        knowledge = max(min_knowledge, int(knowledge_budget * factor))
+        if attempts and attempts[-1]["answer_token_budget"] == answer and attempts[-1]["knowledge_token_budget"] == knowledge:
+            continue
+        attempts.append(
+            {
+                "attempt": index + 1,
+                "answer_token_budget": answer,
+                "knowledge_token_budget": knowledge,
+                "degraded": index > 0,
+            }
+        )
+    return attempts
+
+
+async def _localmathrag_close_async_iter(stream_iter):
+    close = getattr(stream_iter, "aclose", None)
+    if callable(close):
+        try:
+            await close()
+        except Exception:
+            logging.debug("Failed to close timed-out local summary stream", exc_info=True)
+
+
+async def _localmathrag_stream_summary_with_timeout(stream_iter):
+    first_timeout = _localmathrag_float_env("LOCALMATHRAG_SEARCH_SUMMARY_FIRST_TOKEN_TIMEOUT_SECONDS", 120.0, 1.0)
+    idle_timeout = _localmathrag_float_env("LOCALMATHRAG_SEARCH_SUMMARY_IDLE_TIMEOUT_SECONDS", 120.0, 1.0)
+    iterator = _stream_with_think_delta(stream_iter)
+    saw_output = False
+    try:
+        while True:
+            timeout = idle_timeout if saw_output else first_timeout
+            try:
+                item = await asyncio.wait_for(iterator.__anext__(), timeout=timeout)
+            except StopAsyncIteration:
+                break
+            except asyncio.TimeoutError as exc:
+                await _localmathrag_close_async_iter(iterator)
+                phase = "idle" if saw_output else "first-token"
+                raise LocalMathRAGSummaryTimeout(f"local summary {phase} timeout after {timeout:.0f}s") from exc
+            saw_output = True
+            yield item
+    finally:
+        await _localmathrag_close_async_iter(iterator)
+
 
