@@ -168,4 +168,22 @@ def release_auxiliary_index_lease(token: str | None) -> bool:
     try:
         return REDIS_CONN.delete_if_equal(AUXILIARY_INDEX_LOCK_KEY, str(token))
     except Exception:
         return False
+
+
+def release_stale_auxiliary_index_locks(task_id: str | None, kb_id: str | None = None) -> dict[str, bool]:
+    """Release only locks still owned by the task being cancelled or replaced."""
+    task_id = str(task_id or "")
+    if not task_id:
+        return {"auxiliary": False, "graphrag": False}
+
+    released = {"auxiliary": release_auxiliary_index_lease(task_id), "graphrag": False}
+    if kb_id:
+        try:
+            released["graphrag"] = REDIS_CONN.delete_if_equal(
+                f"graphrag_task_{kb_id}",
+                f"batch_merge:{task_id}",
+            )
+        except Exception:
+            released["graphrag"] = False
+    return released
