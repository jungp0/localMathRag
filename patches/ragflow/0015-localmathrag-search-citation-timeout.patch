+def _localmathrag_fast_reference(kbinfos, max_chunks=12):
+    refs = deepcopy(kbinfos)
+    chunks = refs.get("chunks", [])
+    if not isinstance(chunks, list):
+        refs["chunks"] = []
+        return refs
+    refs["chunks"] = chunks[:max_chunks]
+    for chunk in refs["chunks"]:
+        if isinstance(chunk, dict) and chunk.get("vector"):
+            del chunk["vector"]
+    try:
+        refs["chunks"] = chunks_format(refs)
+    except Exception:  # noqa: BLE001 - fallback reference must never block final answer
+        logging.debug("Failed to format fast citation fallback reference", exc_info=True)
+    return refs
