+def refresh_auxiliary_index_lease(token: str | None) -> bool:
+    if not token:
+        return False
+    try:
+        if str(REDIS_CONN.REDIS.get(AUXILIARY_INDEX_LOCK_KEY) or "") != str(token):
+            return False
+        return bool(REDIS_CONN.REDIS.expire(AUXILIARY_INDEX_LOCK_KEY, AUXILIARY_INDEX_LOCK_TTL_SECONDS))
+    except Exception:
+        return False
+
+
 def release_auxiliary_index_lease(token: str | None) -> bool:
     if not token:
         return True
