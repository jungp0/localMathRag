+
+const sanitizeFileName = (value: string) =>
+  value
+    .replace(/[\\/:*?"<>|]/g, '-')
+    .replace(/\s+/g, '-')
+    .slice(0, 80)
+    .replace(/^-+|-+$/g, '') || 'search-results';
+
+const buildSearchExportMarkdown = ({
+  searchName,
+  question,
+  summary,
+  chunks,
+  total,
+}: {
+  searchName?: string;
+  question: string;
+  summary?: string;
+  chunks: any[];
+  total: number;
+}) => {
+  const lines = [
+    '# Search Results',
+    '',
+    `- Search: ${searchName || '-'}`,
+    `- Query: ${question || '-'}`,
+    `- Exported: ${new Date().toLocaleString()}`,
+    `- Total results: ${total ?? chunks.length}`,
+    '',
+    '## AI Summary',
+    '',
+    normalizeExportText(summary) || '_No AI summary._',
+    '',
+    '## Content List',
+    '',
+  ];
+
+  if (!chunks?.length) {
+    lines.push('_No retrieved content._', '');
+    return lines.join('\n');
+  }
+
+  chunks.forEach((chunk, index) => {
+    const docName = chunk.docnm_kwd || chunk.doc_name || chunk.document_name;
+    lines.push(`### ${index + 1}. ${docName || 'Document'}`, '');
+    if (chunk.chunk_id) lines.push(`- Chunk ID: ${chunk.chunk_id}`);
+    if (typeof chunk.similarity === 'number') {
+      lines.push(`- Similarity: ${chunk.similarity.toFixed(4)}`);
+    }
+    if (typeof chunk.vector_similarity === 'number') {
+      lines.push(`- Vector similarity: ${chunk.vector_similarity.toFixed(4)}`);
+    }
+    if (typeof chunk.term_similarity === 'number') {
+      lines.push(`- Term similarity: ${chunk.term_similarity.toFixed(4)}`);
+    }
+    if (
+      chunk.document_metadata &&
+      Object.keys(chunk.document_metadata).length > 0
+    ) {
+      lines.push('- Metadata:');
+      Object.entries(chunk.document_metadata).forEach(([key, value]) => {
+        lines.push(`  - ${key}: ${formatMetadataValue(value)}`);
+      });
+    }
+    lines.push('', normalizeExportText(chunk.content_with_weight), '');
+  });
+
+  return lines.join('\n');
+};
+
+const copyTextToClipboard = async (text: string) => {
+  if (navigator.clipboard?.writeText) {
+    await navigator.clipboard.writeText(text);
+    return;
+  }
+  const textarea = document.createElement('textarea');
+  textarea.value = text;
+  textarea.style.position = 'fixed';
+  textarea.style.opacity = '0';
+  document.body.appendChild(textarea);
+  textarea.select();
+  document.execCommand('copy');
+  document.body.removeChild(textarea);
+};
