diff --git a/api/utils/file_utils.py b/api/utils/file_utils.py
--- a/api/utils/file_utils.py
+++ b/api/utils/file_utils.py
@@ -42,0 +43,39 @@ if LOCK_KEY_pdfplumber not in sys.modules:
+TEMPORARY_FILE_NAMES = frozenset({".ds_store", "desktop.ini", "thumbs.db"})
+TEMPORARY_FILE_SUFFIXES = (
+    ".tmp",
+    ".temp",
+    ".part",
+    ".partial",
+    ".crdownload",
+    ".download",
+    ".swp",
+    ".swo",
+    ".bak",
+    ".old",
+    ".orig",
+    ".lck",
+    ".lock",
+    ".dwl",
+    ".dwl2",
+    ".sv$",
+    ".ac$",
+)
+
+
+def is_temporary_file(filename) -> bool:
+    """Return whether an upload candidate is a known temporary or lock file."""
+    if filename is None or not isinstance(filename, str):
+        return False
+    basename = filename.replace("\\", "/").rsplit("/", 1)[-1].strip()
+    if not basename:
+        return False
+    normalized = basename.casefold()
+    return (
+        "$$" in basename
+        or basename.startswith("~$")
+        or normalized.startswith(".~lock.")
+        or (basename.startswith("#") and basename.endswith("#"))
+        or normalized in TEMPORARY_FILE_NAMES
+        or normalized.endswith(TEMPORARY_FILE_SUFFIXES)
+    )
+
