diff --git a/web/src/utils/file-util.ts b/web/src/utils/file-util.ts
--- a/web/src/utils/file-util.ts
+++ b/web/src/utils/file-util.ts
@@ -4,0 +5,42 @@ import fileManagerService from '@/services/file-manager-service';
+const temporaryUploadFileNames = new Set([
+  '.ds_store',
+  'desktop.ini',
+  'thumbs.db',
+]);
+const temporaryUploadFileSuffixes = [
+  '.tmp',
+  '.temp',
+  '.part',
+  '.partial',
+  '.crdownload',
+  '.download',
+  '.swp',
+  '.swo',
+  '.bak',
+  '.old',
+  '.orig',
+  '.lck',
+  '.lock',
+  '.dwl',
+  '.dwl2',
+  '.sv$',
+  '.ac$',
+];
+
+export const isTemporaryUploadFile = (file: File): boolean => {
+  const path = (file as File & { webkitRelativePath?: string })
+    .webkitRelativePath;
+  const basename = (path || file.name).replaceAll('\\', '/').split('/').pop();
+  if (!basename) return false;
+
+  const normalized = basename.toLocaleLowerCase();
+  return (
+    basename.includes('$$') ||
+    basename.startsWith('~$') ||
+    normalized.startsWith('.~lock.') ||
+    (basename.startsWith('#') && basename.endsWith('#')) ||
+    temporaryUploadFileNames.has(normalized) ||
+    temporaryUploadFileSuffixes.some((suffix) => normalized.endsWith(suffix))
+  );
+};
+
