+# Copyright 2026 LocalMathRAGFlow contributors.
+# Licensed under the Apache License, Version 2.0.
+
+from __future__ import annotations
+
+import os
+
+from common import settings
+from common.constants import SVR_CONSUMER_GROUP_NAME
+from rag.utils.redis_conn import REDIS_CONN
+
+
+DOCUMENT_PARSE_PRIORITY = 1
+AUXILIARY_INDEX_PRIORITY = 0
+AUXILIARY_INDEX_TASK_TYPES = frozenset({"graphrag", "raptor", "mindmap"})
+AUXILIARY_INDEX_LOCK_KEY = "localmathrag:auxiliary-index:active"
+AUXILIARY_INDEX_LOCK_TTL_SECONDS = max(
+    300,
+    int(os.environ.get("LOCALMATHRAG_AUX_INDEX_LOCK_TTL_SECONDS", "86400")),
+)
+
+
+def document_parse_queue_busy(worker_task_type: str = "common") -> bool:
+    queue_name = settings.get_svr_queue_name(DOCUMENT_PARSE_PRIORITY, worker_task_type)
+    try:
+        groups = REDIS_CONN.REDIS.xinfo_groups(queue_name)
+    except Exception as exc:
+        if "no such key" not in str(exc).lower():
+            return True
+        return False
+    for group in groups:
+        if group.get("name") != SVR_CONSUMER_GROUP_NAME:
+            continue
+        return int(group.get("lag", 0) or 0) > 0 or int(group.get("pending", 0) or 0) > 0
+    try:
+        return int(REDIS_CONN.REDIS.xlen(queue_name) or 0) > 0
+    except Exception:
+        return True
+
+
+def acquire_auxiliary_index_lease(task_id: str) -> str | None:
+    token = str(task_id or "")
+    if not token:
+        return None
+    try:
+        if REDIS_CONN.REDIS.set(
+            AUXILIARY_INDEX_LOCK_KEY,
+            token,
+            ex=AUXILIARY_INDEX_LOCK_TTL_SECONDS,
+            nx=True,
+        ):
+            return token
+        owner = REDIS_CONN.REDIS.get(AUXILIARY_INDEX_LOCK_KEY)
+        if owner is not None and str(owner) == token:
+            REDIS_CONN.REDIS.expire(AUXILIARY_INDEX_LOCK_KEY, AUXILIARY_INDEX_LOCK_TTL_SECONDS)
+            return token
+    except Exception:
+        return None
+    return None
+
+
+def release_auxiliary_index_lease(token: str | None) -> bool:
+    if not token:
+        return True
+    try:
+        return REDIS_CONN.delete_if_equal(AUXILIARY_INDEX_LOCK_KEY, str(token))
+    except Exception:
+        return False
