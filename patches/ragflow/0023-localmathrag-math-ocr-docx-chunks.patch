+def _math_ocr_enabled() -> bool:
+    enabled = os.environ.get("LOCALMATHRAG_ENABLE_MATH_OCR", "")
+    normalized = enabled.strip().lower()
+    if bool(os.environ.get("LOCALMATHRAG_MATH_OCR_URL")) or normalized in {"1", "true", "yes", "on"}:
+        return True
+    if normalized in {"auto", ""}:
+        return _math_ocr_service_ready()
+    return False
+
+
+def _math_ocr_service_ready() -> bool:
+    global _MATH_OCR_STATUS_CHECKED_AT, _MATH_OCR_STATUS_READY
+    now = time.monotonic()
+    if now - _MATH_OCR_STATUS_CHECKED_AT < MATH_OCR_STATUS_CACHE_SECONDS:
+        return _MATH_OCR_STATUS_READY
+    _MATH_OCR_STATUS_CHECKED_AT = now
+    try:
+        with urllib.request.urlopen(MATH_OCR_STATUS_URL, timeout=MATH_OCR_STATUS_TIMEOUT_SECONDS) as response:
+            data = json.loads(response.read().decode("utf-8"))
+        _MATH_OCR_STATUS_READY = bool(data.get("configured") or data.get("endpoint_ok"))
+    except Exception as e:
+        logging.info("Math OCR auto check skipped: %s", e)
+        _MATH_OCR_STATUS_READY = False
+    return _MATH_OCR_STATUS_READY
+
+
+def _image_to_png_base64(img):
+    if img.mode not in {"RGB", "L"}:
+        img = img.convert("RGB")
+    buffer = BytesIO()
+    img.save(buffer, format="PNG")
+    return base64.b64encode(buffer.getvalue()).decode("ascii")
+
+
+def _first_math_ocr_text(data):
+    if isinstance(data, str):
+        return data.strip()
+    if isinstance(data, dict):
+        for key in ("latex", "text", "formula", "markdown"):
+            value = data.get(key)
+            if isinstance(value, str) and value.strip():
+                return value.strip()
+        for key in ("result", "data", "results"):
+            value = data.get(key)
+            text = _first_math_ocr_text(value)
+            if text:
+                return text
+    if isinstance(data, list):
+        for value in data:
+            text = _first_math_ocr_text(value)
+            if text:
+                return text
+    return ""
+
+
+def _math_ocr_image(img, context_text=""):
+    if not _math_ocr_enabled():
+        return ""
+    payload = json.dumps(
+        {
+            "image": _image_to_png_base64(img),
+            "mime_type": "image/png",
+            "format": "png",
+            "task": "formula",
+            "context": context_text or "",
+        }
+    ).encode("utf-8")
+    req = urllib.request.Request(
+        MATH_OCR_URL,
+        data=payload,
+        headers={"Content-Type": "application/json"},
+        method="POST",
+    )
+    with urllib.request.urlopen(req, timeout=MATH_OCR_TIMEOUT_SECONDS) as response:
+        data = json.loads(response.read().decode("utf-8"))
+    return _first_math_ocr_text(data)
+
+
+def _append_chunk_text(ck, text):
+    if text:
+        ck["text"] = (ck.get("text") or "").rstrip() + "\n" + text
+
+
+def _enhance_docx_chunks_with_math_ocr(chunks, idx_lst, callback=None):
+    if not _math_ocr_enabled():
+        return
+    if callback:
+        callback(0.69, "Local Math OCR enabled. Parsing Word formula images...")
+    for idx in idx_lst:
+        try:
+            ck = chunks[idx]
+        except Exception:
+            continue
+        img = None
+        close_after = False
+        try:
+            img, close_after = open_image_for_processing(ck.get("image"), allow_bytes=True)
+            if not isinstance(img, Image.Image):
+                continue
+            context_text = " ".join(
+                text
+                for text in (ck.get("context_above"), ck.get("text"), ck.get("context_below"))
+                if text
+            )
+            latex = _math_ocr_image(img, context_text=context_text)
+            if latex:
+                _append_chunk_text(ck, f"[Math OCR LaTeX: {latex}]")
+        except Exception as e:
+            logging.warning("Math OCR skipped for one Word image: %s", e)
+        finally:
+            if close_after and isinstance(img, Image.Image):
+                try:
+                    img.close()
+                except Exception:
+                    pass
+
