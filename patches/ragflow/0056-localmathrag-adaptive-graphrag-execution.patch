+def _checkpoint_digest(content: str) -> str:
+    return hashlib.sha256(content.encode("utf-8", errors="replace")).hexdigest()
+
+
+def _serialize_chunk_checkpoint(kb_id: str, doc_id: str, chunk_index: int, content: str, result: tuple) -> dict:
+    maybe_nodes, maybe_edges, token_count = result
+    payload = {
+        "version": 1,
+        "doc_id": doc_id,
+        "chunk_index": chunk_index,
+        "chunk_digest": _checkpoint_digest(content),
+        "nodes": maybe_nodes,
+        "edges": [{"key": list(key), "values": values} for key, values in maybe_edges.items()],
+        "token_count": token_count,
+    }
+    checkpoint = {
+        "content_with_weight": json.dumps(payload, ensure_ascii=False),
+        "knowledge_graph_kwd": "subgraph_checkpoint",
+        "kb_id": kb_id,
+        "source_id": [doc_id],
+        "available_int": 0,
+        "removed_kwd": "N",
+    }
+    checkpoint["id"] = chunk_id(checkpoint)
+    return checkpoint
+
+
+def _deserialize_chunk_checkpoint(payload: dict, chunks: list[str]) -> tuple[int, tuple] | None:
+    try:
+        index = int(payload["chunk_index"])
+        if payload.get("version") != 1 or index < 0 or index >= len(chunks):
+            return None
+        if payload.get("chunk_digest") != _checkpoint_digest(chunks[index]):
+            return None
+        edges = {tuple(item["key"]): item["values"] for item in payload.get("edges", [])}
+        return index, (payload.get("nodes", {}), edges, int(payload.get("token_count", 0)))
+    except (KeyError, TypeError, ValueError):
+        return None
+
+
+async def load_chunk_checkpoints(tenant_id: str, kb_id: str, doc_id: str, chunks: list[str]) -> dict[int, tuple]:
+    fields = ["content_with_weight", "source_id"]
+    condition = {
+        "knowledge_graph_kwd": ["subgraph_checkpoint"],
+        "removed_kwd": "N",
+        "source_id": [doc_id],
+    }
+    try:
+        result = await thread_pool_exec(
+            settings.docStoreConn.search,
+            fields,
+            [],
+            condition,
+            [],
+            OrderByExpr(),
+            0,
+            max(1, len(chunks) * 2),
+            search.index_name(tenant_id),
+            [kb_id],
+        )
+        checkpoints = {}
+        for row in settings.docStoreConn.get_fields(result, fields).values():
+            parsed = _deserialize_chunk_checkpoint(json.loads(row.get("content_with_weight", "{}")), chunks)
+            if parsed:
+                checkpoints[parsed[0]] = parsed[1]
+        if checkpoints:
+            logging.info("Loaded %s/%s chunk checkpoints for doc %s", len(checkpoints), len(chunks), doc_id)
+        return checkpoints
+    except Exception:
+        logging.exception("Failed to load chunk checkpoints for doc %s", doc_id)
+        return {}
+
+
+async def save_chunk_checkpoint(tenant_id: str, kb_id: str, doc_id: str, chunks: list[str], chunk_index: int, result: tuple) -> None:
+    checkpoint = _serialize_chunk_checkpoint(kb_id, doc_id, chunk_index, chunks[chunk_index], result)
+    insert_error = await thread_pool_exec(
+        settings.docStoreConn.insert,
+        [checkpoint],
+        search.index_name(tenant_id),
+        kb_id,
+    )
+    if insert_error:
+        raise RuntimeError(f"failed to save GraphRAG chunk checkpoint: {insert_error}")
+
+
+async def clear_chunk_checkpoints(tenant_id: str, kb_id: str, doc_id: str) -> None:
+    await thread_pool_exec(
+        settings.docStoreConn.delete,
+        {"knowledge_graph_kwd": "subgraph_checkpoint", "source_id": doc_id},
+        search.index_name(tenant_id),
+        kb_id,
+    )
+
