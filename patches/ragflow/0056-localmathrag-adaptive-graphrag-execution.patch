--- /dev/null
+++ b/rag/graphrag/adaptive.py
@@ -0,0 +1,94 @@
+from __future__ import annotations
+
+import math
+import os
+import time
+from dataclasses import dataclass
+from typing import Callable
+
+
+def _positive_int(value, default: int) -> int:
+    try:
+        parsed = int(value)
+    except (TypeError, ValueError):
+        return default
+    return parsed if parsed > 0 else default
+
+
+@dataclass(frozen=True)
+class GraphRagExecutionPlan:
+    chat_slots: int
+    chunk_slots_per_document: int
+    document_slots: int
+
+
+def resolve_execution_plan(
+    document_count: int,
+    *,
+    configured_document_slots: int | str | None = None,
+    environ: dict[str, str] | None = None,
+) -> GraphRagExecutionPlan:
+    """Resolve GraphRAG concurrency from the model's advertised capacity."""
+
+    env = os.environ if environ is None else environ
+    chat_slots = _positive_int(
+        env.get("LOCALMATHRAG_MODEL_PARALLEL_SLOTS") or env.get("MAX_CONCURRENT_CHATS"),
+        1,
+    )
+    default_chunk_slots = max(1, math.ceil(math.sqrt(chat_slots)))
+    chunk_slots = min(
+        chat_slots,
+        _positive_int(env.get("MAX_CONCURRENT_PROCESS_AND_EXTRACT_CHUNK"), default_chunk_slots),
+    )
+
+    explicit = configured_document_slots
+    if explicit in (None, "", "auto"):
+        explicit = env.get("LOCALMATHRAG_GRAPHRAG_MAX_PARALLEL_DOCS", "auto")
+    if str(explicit).strip().lower() == "auto":
+        document_slots = math.ceil(chat_slots / chunk_slots)
+    else:
+        document_slots = _positive_int(explicit, math.ceil(chat_slots / chunk_slots))
+
+    document_slots = max(1, min(max(1, document_count), document_slots))
+    return GraphRagExecutionPlan(
+        chat_slots=chat_slots,
+        chunk_slots_per_document=chunk_slots,
+        document_slots=document_slots,
+    )
+
+
+class AdaptiveActivityWatchdog:
+    """Inactivity deadline that learns from observed progress intervals."""
+
+    def __init__(
+        self,
+        minimum_timeout_seconds: float,
+        maximum_timeout_seconds: float,
+        *,
+        observed_gap_multiplier: float = 3.0,
+        clock: Callable[[], float] = time.monotonic,
+    ) -> None:
+        self._clock = clock
+        self._minimum = max(0.001, float(minimum_timeout_seconds))
+        self._maximum = max(self._minimum, float(maximum_timeout_seconds))
+        self._multiplier = max(1.0, float(observed_gap_multiplier))
+        self._last_activity = self._clock()
+        self._estimated_gap: float | None = None
+
+    @property
+    def timeout_seconds(self) -> float:
+        learned = 0.0 if self._estimated_gap is None else self._estimated_gap * self._multiplier
+        return min(self._maximum, max(self._minimum, learned))
+
+    def touch(self) -> None:
+        now = self._clock()
+        gap = max(0.0, now - self._last_activity)
+        if gap > 0:
+            if self._estimated_gap is None:
+                self._estimated_gap = gap
+            else:
+                self._estimated_gap = self._estimated_gap * 0.7 + gap * 0.3
+        self._last_activity = now
+
+    def remaining_seconds(self) -> float:
+        return self.timeout_seconds - (self._clock() - self._last_activity)
