+def _resolve_rendered_toc(candidates: list[dict[str, Any]], chunk_count: int) -> list[dict[str, Any]]:
+    if chunk_count < 2:
+        return []
+    leading_chunk_limit = min(chunk_count, max(4, (chunk_count + 9) // 10))
+    rendered = []
+    for item in sorted(candidates, key=lambda value: (value["chunk_id"], value["offset"])):
+        if item["chunk_id"] >= leading_chunk_limit or item["source"] not in {"numbered", "semantic"}:
+            continue
+        title, page = _strip_trailing_page_number(item["title"])
+        if page is None or not _heading_key(title):
+            continue
+        rendered.append((item, title, page))
+    if len(rendered) < 8 or len({page for _item, _title, page in rendered}) < 3:
+        return []
+    monotonic_pairs = sum(
+        current[2] >= previous[2] for previous, current in zip(rendered, rendered[1:])
+    )
+    if monotonic_pairs / max(1, len(rendered) - 1) < 0.75:
+        return []
+
+    toc_end = max((item["chunk_id"], item["offset"]) for item, _title, _page in rendered)
+    body_candidates = [
+        item
+        for item in sorted(candidates, key=lambda value: (value["chunk_id"], value["offset"]))
+        if (item["chunk_id"], item["offset"]) > toc_end
+        and item["source"] in {"numbered", "semantic"}
+        and _strip_trailing_page_number(item["title"])[1] is None
+    ]
+    body_keys = [_heading_key(item["title"]) for item in body_candidates]
+    resolved = []
+    cursor = 0
+    for toc_item, clean_title, _page in rendered:
+        toc_key = _heading_key(clean_title)
+        match_index = None
+        for index in range(cursor, len(body_candidates)):
+            if body_keys[index] == toc_key:
+                match_index = index
+                break
+        if match_index is None:
+            continue
+        body_item = body_candidates[match_index]
+        resolved.append(
+            _candidate(
+                clean_title,
+                body_item["chunk_id"],
+                toc_item["level"],
+                body_item["offset"],
+                "rendered_toc",
+            )
+        )
+        cursor = match_index + 1
+    required_matches = max(6, (len(rendered) + 2) // 3)
+    return resolved if len(resolved) >= required_matches else []
+
