{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localmathragflow.local/schemas/document-object.schema.json",
  "title": "LocalMathRAGFlow Document Object",
  "type": "object",
  "required": ["id", "type", "source"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "technical_parameter",
        "requirement_table_row",
        "formula",
        "table_object",
        "visual_object",
        "flow_diagram"
      ]
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["source_file"],
      "properties": {
        "source_file": {
          "type": "string"
        },
        "document_id": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "sheet": {
          "type": "string"
        },
        "cell_range": {
          "type": "string"
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          }
        },
        "chunk_id": {
          "type": "string"
        },
        "citation_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
