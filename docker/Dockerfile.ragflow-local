ARG RAGFLOW_BASE_IMAGE=infiniflow/ragflow:v0.26.3
FROM ${RAGFLOW_BASE_IMAGE}

USER root
WORKDIR /ragflow

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends libwmf-bin \
    && rm -rf /var/lib/apt/lists/*

ENV LOCALMATHRAG_LOCAL_ONLY=1
ENV LOCALMATHRAG_DISABLE_LOGIN=1
ENV LOCALMATHRAG_MTEF_PARSER=/usr/local/bin/localmathrag-mtef

COPY services/mtef_parser/localmathrag-mtef-linux-amd64 /usr/local/bin/localmathrag-mtef
RUN chmod 0755 /usr/local/bin/localmathrag-mtef

COPY docker/ragflow-localize-conf.py /tmp/ragflow-localize-conf.py
RUN python /tmp/ragflow-localize-conf.py

COPY third_party/ragflow/api/apps/services/provider_api_service.py /ragflow/api/apps/services/provider_api_service.py
COPY third_party/ragflow/api/apps/services/dataset_api_service.py /ragflow/api/apps/services/dataset_api_service.py
